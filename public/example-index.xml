<?xml version="1.0" encoding="UTF-8"?>
<document>
  <!-- Carousel Section - Banner images for the homepage hero -->
  <!-- videourl: Optional - links banner to a video player page -->
  <!-- islive: Optional - marks this as a live stream banner -->
  <carousel>
    <section>
      <lockup islive="true">
        <img src="https://example.com/banners/live-banner.jpg" width="1740" height="500" />
      </lockup>
      <lockup videourl="https://example.com/videos/featured1.m3u8" videoid="featured-1">
        <img src="https://example.com/banners/banner1.jpg" width="1740" height="500" />
      </lockup>
      <lockup videourl="https://example.com/videos/featured2.m3u8" videoid="featured-2">
        <img src="https://example.com/banners/banner2.jpg" width="1740" height="500" />
      </lockup>
      <lockup>
        <img src="https://example.com/banners/banner3.jpg" width="1740" height="500" />
      </lockup>
    </section>
  </carousel>

  <!-- Category 1: Featured Sets -->
  <!-- Each lockup can have: videourl (HLS stream), videoid (unique ID), duration -->
  <separator>
    <button documenturl="/pages/featured.xml">
      <text>Featured Sets</text>
    </button>
  </separator>
  <shelf>
